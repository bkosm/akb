{
  "mcpServers": {
    "akb-local": {
      "command": "stdio.sh",
      "args": ["local"]
    },
    "akb-s3": {
      "command": "stdio.sh",
      "args": ["s3"]
    },
    "akb-docker-local": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-v", "~/.config/akb:/home/akb/.config/akb",
        "ghcr.io/bkosm/akb:main",
        "local", "--path", "/home/akb/.config/akb/config.json"
      ]
    },
    "akb-docker-s3": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "AWS_PROFILE",
        "-e", "AWS_SDK_LOAD_CONFIG=1",
        "-v", "~/.aws/config:/root/.aws/config:ro",
        "-v", "~/.aws/sso/cache:/root/.aws/sso/cache:ro",
        "-v", "~/.aws/cli/cache:/root/.aws/cli/cache:ro",
        "ghcr.io/bkosm/akb:main",
        "s3"
      ]
    }
  }
}
