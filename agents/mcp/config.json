{
  "mcpServers": {
    "akb-local": {
      "command": "stdio.sh",
      "args": ["local"]
    },
    "akb-s3": {
      "command": "stdio.sh",
      "args": ["s3"]
    },
    "akb-docker-local": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-v", "~/.config/akb:/home/akb/.config/akb",
        "ghcr.io/bkosm/akb:main",
        "local", "--path", "/home/akb/.config/akb/config.json"
      ]
    },
    "akb-docker-s3": {
      "command": "akb-docker-s3.sh",
      "args": []
    }
  }
}
